# Optional local environment variables.
# Do not copy real tokens into committed files.
#
# Preferred for notebooks:
# - run `huggingface-cli login`, or
# - execute the notebook cell that calls `notebook_login()`.
#
# If you need a local token for scripts, create a read/write token in
# https://huggingface.co/settings/tokens and keep it only in `.env`.

HF_TOKEN=hf_your_token_here
